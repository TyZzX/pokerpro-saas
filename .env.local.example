# ============================================================
# POKERPRO SAAS — VARIABLES D'ENVIRONNEMENT
# Copiez ce fichier en .env.local et remplissez les valeurs
# NE JAMAIS commiter .env.local dans git !
# ============================================================

# --- NEXT.JS ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- SUPABASE ---
# Trouvez ces valeurs dans : https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre_anon_key_ici
SUPABASE_SERVICE_ROLE_KEY=votre_service_role_key_ici

# --- STRIPE ---
# Trouvez ces valeurs dans : https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_VOTRE_CLE_PUBLISHABLE
STRIPE_SECRET_KEY=sk_test_VOTRE_CLE_SECRETE
STRIPE_WEBHOOK_SECRET=whsec_VOTRE_WEBHOOK_SECRET

# --- STRIPE PRICE IDs ---
# Créez les produits dans Stripe Dashboard → Products
# Copiez les Price IDs (commencent par price_)
STRIPE_STANDARD_PRICE_ID=price_STANDARD_MENSUEL
STRIPE_PREMIUM_PRICE_ID=price_PREMIUM_MENSUEL

# --- ADMIN ---
# Email de l'administrateur (accès au dashboard admin)
ADMIN_EMAIL=admin@votresite.com
